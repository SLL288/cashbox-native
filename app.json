{
  "expo": {
    "name": "Cashbox",
    "slug": "cashbox-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cashboxnative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allenlsl.cashboxnative",
      "infoPlist": {
        "CFBundleDisplayName": "Cashbox",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.allenlsl.cashboxnative",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Cashbox to access receipt photos.",
          "savePhotosPermission": "Allow Cashbox to save receipt photos.",
          "granularPermissions": ["photo"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db5e383d-d54a-49df-bc0c-a25cbe18ea6c"
      }
    }
  }
}
